diff --git a/public/fpdf_annot.h b/public/fpdf_annot.h
index 0aa9f6886..7687be1d3 100644
--- a/public/fpdf_annot.h
+++ b/public/fpdf_annot.h
@@ -842,6 +842,53 @@ FPDFAnnot_IsOptionSelected(FPDF_FORMHANDLE handle,
                            FPDF_ANNOTATION annot,
                            int index);
 
+// Experimental API.
+// Append a label-only option to |annot|'s "Opt" array. Creates the
+// "Opt" entry on the annotation's terminal form field if it doesn't
+// already exist. Intended for use with combobox, listbox, checkbox,
+// and radio button widget annotations (the same set as
+// FPDFAnnot_GetOptionCount accepts).
+//
+//   hHandle - handle to the form fill module, returned by
+//             FPDFDOC_InitFormFillEnvironment.
+//   annot   - handle to an annotation.
+//   label   - UTF-16LE encoded option label.
+//
+// Returns the 0-based index at which the new option was appended in
+// the "Opt" array. Returns -1 if |annot| does not support an "Opt"
+// array (e.g. it's a text field), if |hHandle| is invalid, or if
+// |label| is NULL.
+//
+// If |annot|'s terminal field inherits its "Opt" array from an
+// ancestor field in the form-field tree, this function copies the
+// inherited array down onto the terminal field's own dictionary
+// before appending, so that the new option only affects |annot| and
+// any sibling widgets that share its terminal field — never a
+// parent or unrelated sibling tree.
+FPDF_EXPORT int FPDF_CALLCONV
+FPDFAnnot_AppendOption(FPDF_FORMHANDLE hHandle,
+                       FPDF_ANNOTATION annot,
+                       FPDF_WIDESTRING label);
+
+// Experimental API.
+// Remove |annot|'s entire "Opt" array. Intended for use with
+// combobox, listbox, checkbox, and radio button widget annotations.
+// Use this before a sequence of FPDFAnnot_AppendOption() calls when
+// you want to replace the entire option list rather than extend it.
+//
+//   hHandle - handle to the form fill module, returned by
+//             FPDFDOC_InitFormFillEnvironment.
+//   annot   - handle to an annotation.
+//
+// Returns true if the "Opt" key was present on the terminal field's
+// dictionary and is now removed. Returns false if |annot| does not
+// support an "Opt" array, |hHandle| is invalid, or the field did
+// not have a directly-owned "Opt" entry (note: returns false even
+// when an inherited "Opt" remains visible via FPDFAnnot_GetOption*,
+// since this function only removes the field's own entry).
+FPDF_EXPORT FPDF_BOOL FPDF_CALLCONV
+FPDFAnnot_RemoveOptions(FPDF_FORMHANDLE hHandle, FPDF_ANNOTATION annot);
+
