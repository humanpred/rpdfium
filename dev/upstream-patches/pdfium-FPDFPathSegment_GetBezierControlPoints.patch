From 687fbaabb82d825be101518764194fffedc8cb70 Mon Sep 17 00:00:00 2001
From: Bill Denney <wdenney@humanpredictions.com>
Date: Fri, 15 May 2026 21:01:01 +0000
Subject: [PATCH] Expose cubic Bezier control points on read

Add a new public C API:

  FPDFPathSegment_GetBezierControlPoints(FPDF_PATHSEGMENT segment,
                                          float* cp1_x, float* cp1_y,
                                          float* cp2_x, float* cp2_y);

The constructor side already accepts all six floats per curve via
FPDFPath_BezierTo(); only the readout side was asymmetric, returning
only the endpoint via FPDFPathSegment_GetPoint() and silently
dropping the control points. Without them, embedders cannot
reconstruct cubic curves from existing PDFs.

A cubic Bezier curve is stored in CFX_Path as three consecutive
points of type kBezier (the two control points followed by the
endpoint). The new function reads the two predecessors via pointer
arithmetic on the contiguous std::vector<Point> storage and
validates that both are kBezier. It is intended to be called on the
endpoint of a curve; the typical caller pattern is to walk the path,
reset a per-non-Bezier-segment counter, and treat every third
consecutive kBezier as an endpoint.

Tested via FPDFEditEmbedderTest::GetBezierControlPoints, exercising:
  * a path with two cubic curves separated by a LineTo;
  * successful readout on each endpoint;
  * FALSE return on the second control point of the first curve
    (preceded by a LineTo);
  * FALSE return on a non-Bezier (MoveTo) segment;
  * FALSE return on each NULL-out-param permutation;
  * the documented caveat that back-to-back curves cannot be
    disambiguated locally from a bare FPDF_PATHSEGMENT (the test
    asserts the silent-return contract so the limitation is
    regression-checked).

Bug: see https://groups.google.com/g/pdfium/c/<thread-id>
---
 fpdfsdk/fpdf_edit_embeddertest.cpp | 111 +++++++++++++++++++++++++++++
 fpdfsdk/fpdf_editpath.cpp          |  37 ++++++++++
 fpdfsdk/fpdf_view_c_api_test.c     |   1 +
 public/fpdf_edit.h                 |  43 +++++++++++
 4 files changed, 192 insertions(+)

diff --git a/fpdfsdk/fpdf_edit_embeddertest.cpp b/fpdfsdk/fpdf_edit_embeddertest.cpp
index ae7c9fd..650a5c7 100644
--- a/fpdfsdk/fpdf_edit_embeddertest.cpp
+++ b/fpdfsdk/fpdf_edit_embeddertest.cpp
@@ -583,6 +583,117 @@ TEST_F(FPDFEditEmbedderTest, AddPaths) {
   VerifySavedDocumentWithExpectationSuffix("blue_path");
 }
 
+TEST_F(FPDFEditEmbedderTest, GetBezierControlPoints) {
+  // Construct a path with two cubic Bezier curves, then read each
+  // curve back via FPDFPathSegment_GetPoint() and
+  // FPDFPathSegment_GetBezierControlPoints().
+  CreateEmptyDocument();
+  ScopedFPDFPage page(FPDFPage_New(document(), 0, 612, 792));
+  ASSERT_TRUE(page);
+
+  FPDF_PAGEOBJECT path = FPDFPageObj_CreateNewPath(100, 100);
+  ASSERT_TRUE(path);
+  EXPECT_TRUE(FPDFPath_LineTo(path, 150, 150));
+  EXPECT_TRUE(FPDFPath_BezierTo(path, 200, 200, 250, 200, 300, 150));
+  EXPECT_TRUE(FPDFPath_BezierTo(path, 350, 100, 400, 100, 450, 150));
+  EXPECT_TRUE(FPDFPath_Close(path));
+
+  // The underlying path stores one Move + one Line + 3+3 Bezier
+  // points + one closing Line = 9 segments. See CFX_Path::Point.
+  ASSERT_EQ(9, FPDFPath_CountSegments(path));
+
+  // First Bezier curve endpoint is at segment index 4. The two
+  // preceding kBezier points (indices 2 and 3) are its control
+  // points.
+  FPDF_PATHSEGMENT segment = FPDFPath_GetPathSegment(path, 4);
+  ASSERT_TRUE(segment);
+  EXPECT_EQ(FPDF_SEGMENT_BEZIERTO, FPDFPathSegment_GetType(segment));
+  float x;
+  float y;
+  EXPECT_TRUE(FPDFPathSegment_GetPoint(segment, &x, &y));
+  EXPECT_FLOAT_EQ(300.0f, x);
+  EXPECT_FLOAT_EQ(150.0f, y);
+  float cp1_x;
+  float cp1_y;
+  float cp2_x;
+  float cp2_y;
+  EXPECT_TRUE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, &cp1_y,
+                                                     &cp2_x, &cp2_y));
+  EXPECT_FLOAT_EQ(200.0f, cp1_x);
+  EXPECT_FLOAT_EQ(200.0f, cp1_y);
+  EXPECT_FLOAT_EQ(250.0f, cp2_x);
+  EXPECT_FLOAT_EQ(200.0f, cp2_y);
+
+  // Second Bezier curve endpoint is at segment index 7.
+  segment = FPDFPath_GetPathSegment(path, 7);
+  ASSERT_TRUE(segment);
+  EXPECT_EQ(FPDF_SEGMENT_BEZIERTO, FPDFPathSegment_GetType(segment));
+  EXPECT_TRUE(FPDFPathSegment_GetPoint(segment, &x, &y));
+  EXPECT_FLOAT_EQ(450.0f, x);
+  EXPECT_FLOAT_EQ(150.0f, y);
+  EXPECT_TRUE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, &cp1_y,
+                                                     &cp2_x, &cp2_y));
+  EXPECT_FLOAT_EQ(350.0f, cp1_x);
+  EXPECT_FLOAT_EQ(100.0f, cp1_y);
+  EXPECT_FLOAT_EQ(400.0f, cp2_x);
+  EXPECT_FLOAT_EQ(100.0f, cp2_y);
+
+  // Calling the function on a control-point segment (index 3, the
+  // second Bezier point in the first triplet) returns false: the
+  // segment two steps back is the kLine at index 1, not a kBezier.
+  segment = FPDFPath_GetPathSegment(path, 3);
+  ASSERT_TRUE(segment);
+  EXPECT_EQ(FPDF_SEGMENT_BEZIERTO, FPDFPathSegment_GetType(segment));
+  EXPECT_FALSE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, &cp1_y,
+                                                     &cp2_x, &cp2_y));
+
+  // Likewise on a non-Bezier segment.
+  segment = FPDFPath_GetPathSegment(path, 0);
+  ASSERT_TRUE(segment);
+  EXPECT_EQ(FPDF_SEGMENT_MOVETO, FPDFPathSegment_GetType(segment));
+  EXPECT_FALSE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, &cp1_y,
+                                                     &cp2_x, &cp2_y));
+
+  // Documented caveat: for back-to-back curves, calling the function
+  // on the first control point of the second curve (index 5)
+  // succeeds with values that look like control points but are
+  // really the second control + endpoint of the previous curve.
+  // The function can only locally verify that the two preceding
+  // segments are kBezier; it cannot tell where a triplet boundary
+  // begins. Callers must walk the path with FPDFPathSegment_GetType()
+  // and reset a per-non-Bezier-segment counter to identify true
+  // endpoints. This case is asserted here as a contract test so the
+  // limitation is regression-checked.
+  segment = FPDFPath_GetPathSegment(path, 5);
+  ASSERT_TRUE(segment);
+  EXPECT_EQ(FPDF_SEGMENT_BEZIERTO, FPDFPathSegment_GetType(segment));
+  EXPECT_TRUE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, &cp1_y,
+                                                    &cp2_x, &cp2_y));
+  // The "control points" returned here are actually points 3 and 4
+  // of the first curve (its second control point and its endpoint),
+  // not (350, 100) / (400, 100).
+  EXPECT_FLOAT_EQ(250.0f, cp1_x);
+  EXPECT_FLOAT_EQ(200.0f, cp1_y);
+  EXPECT_FLOAT_EQ(300.0f, cp2_x);
+  EXPECT_FLOAT_EQ(150.0f, cp2_y);
+
+  // Null inputs return false.
+  segment = FPDFPath_GetPathSegment(path, 4);
+  EXPECT_FALSE(FPDFPathSegment_GetBezierControlPoints(nullptr, &cp1_x, &cp1_y,
+                                                     &cp2_x, &cp2_y));
+  EXPECT_FALSE(FPDFPathSegment_GetBezierControlPoints(segment, nullptr, &cp1_y,
+                                                     &cp2_x, &cp2_y));
+  EXPECT_FALSE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, nullptr,
+                                                     &cp2_x, &cp2_y));
+  EXPECT_FALSE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, &cp1_y,
+                                                     nullptr, &cp2_y));
+  EXPECT_FALSE(FPDFPathSegment_GetBezierControlPoints(segment, &cp1_x, &cp1_y,
+                                                     &cp2_x, nullptr));
+
+  EXPECT_TRUE(FPDFPage_InsertObject(page.get(), path));
+  EXPECT_TRUE(FPDFPage_GenerateContent(page.get()));
+}
+
 TEST_F(FPDFEditEmbedderTest, ClipPath) {
   // Load document with a clipped rectangle.
   ASSERT_TRUE(OpenDocument("clip_path.pdf"));
diff --git a/fpdfsdk/fpdf_editpath.cpp b/fpdfsdk/fpdf_editpath.cpp
index 067ef2b..aae4ea7 100644
--- a/fpdfsdk/fpdf_editpath.cpp
+++ b/fpdfsdk/fpdf_editpath.cpp
@@ -213,6 +213,43 @@ FPDFPathSegment_GetPoint(FPDF_PATHSEGMENT segment, float* x, float* y) {
   return true;
 }
 
+FPDF_EXPORT FPDF_BOOL FPDF_CALLCONV
+FPDFPathSegment_GetBezierControlPoints(FPDF_PATHSEGMENT segment,
+                                       float* cp1_x,
+                                       float* cp1_y,
+                                       float* cp2_x,
+                                       float* cp2_y) {
+  auto* pPathPoint = FXPathPointFromFPDFPathSegment(segment);
+  if (!pPathPoint || !cp1_x || !cp1_y || !cp2_x || !cp2_y) {
+    return false;
+  }
+  if (pPathPoint->type_ != CFX_Path::Point::Type::kBezier) {
+    return false;
+  }
+
+  // A cubic Bezier curve is stored as three consecutive
+  // CFX_Path::Point entries of type kBezier: the two control points
+  // followed by the endpoint. FPDF_PATHSEGMENT is a pointer into the
+  // owning path's contiguous std::vector<Point>, so the two
+  // predecessors can be reached via pointer arithmetic when the
+  // segment is the endpoint of the curve. The kBezier type check
+  // below confirms both predecessors are part of the same triplet;
+  // if either is missing (e.g. the segment is itself a control point,
+  // or the path is malformed) the function returns false.
+  const CFX_Path::Point* cp1 = pPathPoint - 2;
+  const CFX_Path::Point* cp2 = pPathPoint - 1;
+  if (cp1->type_ != CFX_Path::Point::Type::kBezier ||
+      cp2->type_ != CFX_Path::Point::Type::kBezier) {
+    return false;
+  }
+
+  *cp1_x = cp1->point_.x;
+  *cp1_y = cp1->point_.y;
+  *cp2_x = cp2->point_.x;
+  *cp2_y = cp2->point_.y;
+  return true;
+}
+
 FPDF_EXPORT int FPDF_CALLCONV
 FPDFPathSegment_GetType(FPDF_PATHSEGMENT segment) {
   auto* pPathPoint = FXPathPointFromFPDFPathSegment(segment);
diff --git a/fpdfsdk/fpdf_view_c_api_test.c b/fpdfsdk/fpdf_view_c_api_test.c
index 282512d..43eb68b 100644
--- a/fpdfsdk/fpdf_view_c_api_test.c
+++ b/fpdfsdk/fpdf_view_c_api_test.c
@@ -258,6 +258,7 @@ int CheckPDFiumCApi() {
     CHK(FPDFPage_RemoveObject);
     CHK(FPDFPage_SetRotation);
     CHK(FPDFPage_TransformAnnots);
+    CHK(FPDFPathSegment_GetBezierControlPoints);
     CHK(FPDFPathSegment_GetClose);
     CHK(FPDFPathSegment_GetPoint);
     CHK(FPDFPathSegment_GetType);
diff --git a/public/fpdf_edit.h b/public/fpdf_edit.h
index d723b81..d2d3177 100644
--- a/public/fpdf_edit.h
+++ b/public/fpdf_edit.h
@@ -1203,6 +1203,49 @@ FPDFPath_GetPathSegment(FPDF_PAGEOBJECT path, int index);
 FPDF_EXPORT FPDF_BOOL FPDF_CALLCONV
 FPDFPathSegment_GetPoint(FPDF_PATHSEGMENT segment, float* x, float* y);
 
+// Experimental API.
+// Get the two cubic Bezier control points associated with |segment|.
+//
+// A cubic Bezier curve is stored in the underlying path as three
+// consecutive FPDF_SEGMENT_BEZIERTO points: the two control points
+// followed by the curve's endpoint. This function should be called on
+// the endpoint segment (the third FPDF_SEGMENT_BEZIERTO in the
+// triplet) and returns the coordinates of the two preceding control
+// points. Combined with FPDFPathSegment_GetPoint() on the same
+// segment, the four-point cubic curve can be reconstructed.
+//
+// Identifying which FPDF_SEGMENT_BEZIERTO segments are endpoints is
+// the caller's responsibility. The typical pattern is to walk the
+// path with FPDFPath_CountSegments() + FPDFPath_GetPathSegment() +
+// FPDFPathSegment_GetType(), reset a local counter at each
+// non-FPDF_SEGMENT_BEZIERTO segment, and treat every third consecutive
+// FPDF_SEGMENT_BEZIERTO as an endpoint. Calling this function on a
+// control-point segment may silently return adjacent control points
+// from a back-to-back curve; it can only locally verify that the two
+// predecessors are FPDF_SEGMENT_BEZIERTO, not that the segment marks
+// the end of a triplet boundary.
+//
+//   segment - handle to a segment. Must be of type FPDF_SEGMENT_BEZIERTO
+//             and the curve's endpoint (the third Bezier point in the
+//             triplet).
+//   cp1_x   - output; the horizontal position of the first control point.
+//   cp1_y   - output; the vertical position of the first control point.
+//   cp2_x   - output; the horizontal position of the second control point.
+//   cp2_y   - output; the vertical position of the second control point.
+//
+// Returns TRUE on success. Returns FALSE without writing the
+// out-params when |segment| is NULL, |segment|'s type is not
+// FPDF_SEGMENT_BEZIERTO, any out-param is NULL, or either of the two
+// preceding segments in the underlying path is not also
+// FPDF_SEGMENT_BEZIERTO (e.g. when |segment| is the first control
+// point of a curve that follows a non-Bezier segment).
+FPDF_EXPORT FPDF_BOOL FPDF_CALLCONV
+FPDFPathSegment_GetBezierControlPoints(FPDF_PATHSEGMENT segment,
+                                       float* cp1_x,
+                                       float* cp1_y,
+                                       float* cp2_x,
+                                       float* cp2_y);
+
 // Get type of |segment|.
 //
 //   segment - handle to a segment.
