linters: linters_with_defaults(
    line_length_linter(100L),
    object_name_linter = NULL,
    object_length_linter(40L),
    cyclocomp_linter(20L),
    indentation_linter(indent = 2L)
  )
exclusions: list(
    "R/RcppExports.R",
    "tests/testthat/setup.R",
    "tests/testthat/helper-fixtures.R",
    "tools/build-fixtures.R",
    "tools/download-pdfium.R"
  )
encoding: "UTF-8"
