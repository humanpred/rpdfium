src-i386/

# Downloaded binaries (configure populates these; never commit)
inst/include/
inst/lib/

# pkgdown build output. pkgdown writes to `docs/`; hand-written
# developer content lives under `dev/` (tracked) so the two never
# collide. We never commit the rendered site - it's deployed to the
# gh-pages branch by .github/workflows/pkgdown.yaml.
docs/

# Survey scratch (Phase 0)
tmp/
.tmp/

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

