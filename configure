#!/usr/bin/env sh
# pdfium R package — POSIX configure script.
#
# Run by `R CMD INSTALL`. Downloads the pinned bblanchon PDFium binary for
# the current platform, copies headers / libraries into inst/include and
# inst/lib, then writes src/Makevars with the resolved paths and a
# relocatable RPATH so the installed `pdfium.so` finds `libpdfium.so` at
# load time without LD_LIBRARY_PATH.
#
# Honors:
#   R_HOME, R            picked up automatically from R CMD INSTALL
#   PDFIUM_OFFLINE=1     skip download; require vendored archive under
#                        inst/pdfium-binaries/
#   PDFIUM_BINARY_URL    override download URL (mirrors, internal hosts)
#   PDFIUM_CACHE_DIR     cross-build archive cache directory
#
# CRAN-builder note: CRAN allows configure-time downloads (precedent: arrow).
# Set PDFIUM_OFFLINE=1 and ship the archive inside the source tarball under
# inst/pdfium-binaries/ if that ever changes.

set -eu

PKG_ROOT="$(cd "$(dirname "$0")" && pwd)"
RSCRIPT="${R_HOME:-/usr/lib/R}/bin/Rscript"
if [ ! -x "$RSCRIPT" ]; then
  if command -v Rscript >/dev/null 2>&1; then
    RSCRIPT="$(command -v Rscript)"
  else
    echo "ERROR: Rscript not found; cannot run tools/download-pdfium.R" >&2
    exit 1
  fi
fi

echo "[pdfium configure] Resolving binary for $(uname -sm)"
RESOLVED="$("$RSCRIPT" --vanilla "$PKG_ROOT/tools/download-pdfium.R" "$PKG_ROOT")"
PDFIUM_INCLUDE="$(printf '%s\n' "$RESOLVED" | sed -n '1p')"
PDFIUM_LIB="$(printf '%s\n'    "$RESOLVED" | sed -n '2p')"

if [ -z "$PDFIUM_INCLUDE" ] || [ -z "$PDFIUM_LIB" ]; then
  echo "ERROR: tools/download-pdfium.R did not return include / lib paths" >&2
  exit 1
fi

# RPATH so the installed pdfium.so finds libpdfium relative to itself.
# After install, libpdfium.{so,dylib} sits in <pkg>/lib/ (from inst/lib)
# and pdfium.so sits in <pkg>/libs/<R_ARCH>/, so RPATH points one level
# up plus into lib/.
#
# The dollar sign survives Make (which sees $$ORIGIN and produces $ORIGIN)
# and the recipe shell (which receives a single-quoted token from the
# heredoc, so $ORIGIN is not parameter-expanded).
case "$(uname -s)" in
  Darwin)
    RPATH_FLAG="-Wl,-rpath,'@loader_path/../lib'"
    ;;
  Linux)
    RPATH_FLAG='-Wl,-rpath,'"'"'$$ORIGIN/../lib'"'"
    ;;
  *)
    RPATH_FLAG=""
    ;;
esac

cat > "$PKG_ROOT/src/Makevars" <<MAKEVARS
# Generated by configure. Do not edit by hand; edit src/Makevars.in and the
# configure script.
PKG_CPPFLAGS = -I$PDFIUM_INCLUDE -DR_NO_REMAP
PKG_CXXFLAGS = \$(CXX_VISIBILITY)
PKG_LIBS    = -L$PDFIUM_LIB -lpdfium $RPATH_FLAG

CXX_STD = CXX17
MAKEVARS

echo "[pdfium configure] Wrote src/Makevars (include=$PDFIUM_INCLUDE, lib=$PDFIUM_LIB)"
